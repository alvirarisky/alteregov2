rules_version = '2'; 
service cloud.firestore {   
  match /databases/{database}/documents {     
    function signedIn() {       
      return request.auth != null;     
    }     
    function isOwner(uid) {       
      return signedIn() && request.auth.uid == uid;     
    }     
    
    match /users/{uid} {       
      // REVISI KRUSIAL: Buka akses read/write agar user bisa update profilnya sendiri
      allow read, write: if isOwner(uid);       
      
      match /personaChats/{persona} {         
        allow read, write: if false;         
        match /messages/{messageId} {           
          allow get, list: if isOwner(uid);           
          allow create: if isOwner(uid)             
            && request.resource.data.keys().hasOnly(['sender', 'message', 'persona', 'timestamp'])             
            && request.resource.data.sender is string             
            && request.resource.data.message is string             
            && request.resource.data.persona is string             
            && (!('timestamp' in request.resource.data) || request.resource.data.timestamp is timestamp);           
          allow update, delete: if isOwner(uid);         
        }       
      }       
      
      match /reflections/{reflectionId} {         
        allow get, list: if isOwner(uid);         
        allow create: if isOwner(uid)           
          && request.resource.data.keys().hasAll(['mood', 'tags', 'note', 'createdAt'])           
          && request.resource.data.mood is int           
          && request.resource.data.tags is list           
          && request.resource.data.note is string           
          && request.resource.data.createdAt is timestamp;         
        allow update, delete: if isOwner(uid);       
      }     
    }     
    match /{document=**} {       
      allow read, write: if false;     
    }
  }
}